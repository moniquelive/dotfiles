{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "./plugin/obsidian-env.js"
  ],
  "mcp": {
    "browsermcp": {
      "type": "local",
      "command": [
        "/opt/homebrew/opt/mise/bin/mise",
        "exec",
        "--",
        "npx",
        "@browsermcp/mcp@latest"
      ],
      "enabled": false
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "/opt/homebrew/opt/mise/bin/mise",
        "exec",
        "--",
        "npx",
        "chrome-devtools-mcp@latest",
        "--autoConnect"
      ],
      "enabled": true
    },
    "obsidian": {
      "type": "remote",
      "url": "https://127.0.0.1:27124/mcp/",
      "enabled": true,
      "oauth": false
    }
  }
}
