{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "tolaria": {
      "type": "local",
      "command": [
        "/opt/homebrew/bin/node",
        "/Applications/Tolaria.app/Contents/Resources/mcp-server/index.js"
      ],
      "enabled": true,
      "environment": {
        "VAULT_PATH": "/Users/cyber/Library/Mobile Documents/iCloud~md~obsidian/Documents/Personal",
        "WS_UI_PORT": "9711"
      }
    },
    "browsermcp": {
      "type": "local",
      "command": [
        "/opt/homebrew/opt/mise/bin/mise",
        "exec",
        "--",
        "npx",
        "@browsermcp/mcp@latest"
      ],
      "enabled": false
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "/opt/homebrew/opt/mise/bin/mise",
        "exec",
        "--",
        "npx",
        "chrome-devtools-mcp@latest"
      ],
      "enabled": true
    }
  }
}
